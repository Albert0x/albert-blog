# =============================================================================
# 老王说明：环境变量示例
# 实际使用：复制本文件为 .env.local（已经在 .gitignore，不会进 git），填入真实值
# =============================================================================

# ===== AI 博客助手（必填，否则 AI 按钮会显示「未配置」提示）=====
# 申请 DeepSeek API Key：https://platform.deepseek.com
# 注册后充值 ¥10 够用很久（个人博客访问量下大概能聊 5000~10000 次）
DEEPSEEK_API_KEY=sk-请替换为你的真实key

# ===== AI 助手开关（应急用）=====
# 默认开启。若发现被刷或要紧急下线，在 Vercel 改成 "false"，重新部署即可
# AI_ENABLED=true

# ===== 博客管理后台（NextAuth.js + GitHub OAuth）=====
# 配置步骤（一次性，10 分钟）：
#   1. 打开 https://github.com/settings/developers → New OAuth App
#   2. 填表：
#        Application name:        Albert Blog Admin
#        Homepage URL:            https://albert0x.vercel.app
#        Authorization callback URL: https://albert0x.vercel.app/api/auth/callback/github
#      （本地额外加一个：http://localhost:3001/api/auth/callback/github）
#   3. 注册后拿到 Client ID 和 Client Secret 填到下面
#   4. 把 ADMIN_GITHUB_LOGIN 改成你的 GitHub 用户名（多人用逗号分隔）
#   5. 运行 `npx auth secret` 生成 AUTH_SECRET
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
ADMIN_GITHUB_LOGIN=Albert0x

# 仓库定位（哪个 repo 接收文章 commit）
GITHUB_REPO_OWNER=Albert0x
GITHUB_REPO_NAME=albert-blog
# GITHUB_REPO_BRANCH=main   # 默认 main，可选

# ===== 文章点赞系统（Upstash Redis）=====
# 配置步骤：
#   1. 打开 Vercel 项目 → Storage 标签 → Create Database
#   2. 选 "Upstash Redis"（免费版每月 10000 commands 够用）
#   3. 创建后 Vercel 会自动注入下面这两个环境变量到 Production
#   4. 本地开发想测点赞？运行：vercel env pull .env.local 拉取
#   5. 不配置 = 点赞按钮自动隐藏，不影响博客其他功能
KV_REST_API_URL=
KV_REST_API_TOKEN=
# 兼容 Marketplace 新集成（如果上面两个是空的，会用下面这两个）
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ===== 其他可选环境变量（暂未使用，留作未来扩展）=====
# OPENAI_API_KEY=
# NEXT_PUBLIC_GA_ID=
